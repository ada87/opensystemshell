{
  "name": "opensystemshell",
  "displayName": "Open In System Shell",
  "description": "Quick open system terminal",
  "version": "0.1.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "opensystemshell.openFolderInTerminal",
        "title": "Open in System Shell",
        "icon": "$(terminal)"
      }
    ],
    "configuration": {
      "title": "Open In System Shell",
      "properties": {
        "opensystemshell.showInContextMenu": {
          "type": "boolean",
          "default": true,
          "description": "Show 'Open in System Shell' in the explorer context menu"
        }
      }
    },
    "menus": {
      "explorer/context": [
        {
          "when": "config.opensystemshell.showInContextMenu",
          "command": "opensystemshell.openFolderInTerminal",
          "group": "1_modification@99"
        }
      ]
    },
    "keybindings": [
      {
        "command": "opensystemshell.openFolderInTerminal",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "editorTextFocus || filesExplorerFocus || !editorFocus"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "test": "node ./test/runTest.js",
    "vscode:prepublish": "echo 'Preparing to package extension'"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "eslint": "^8.45.0",
    "vscode-test": "^1.6.1",
    "yo": "^4.3.1",
    "generator-code": "^1.8.3"
  },
  "publisher": "xiangda",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ada87/opensystemshell.git"
  },
  "icon": "icon.png"
}
